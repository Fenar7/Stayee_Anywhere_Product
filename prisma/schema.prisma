// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 4.1 User & Role Models
// ==========================================

enum UserRole {
  MAIN_ADMIN
  WARDEN
  TENANT
}

model User {
  id                String       @id @default(uuid())
  cognitoSub        String       @unique
  phone             String       @unique
  email             String?      @unique
  passwordSetAt     DateTime?
  plainTextPassword String?
  hashedPassword    String?
  role              UserRole
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Inverse relations
  warden            Warden?
  tenant            Tenant?
  statusEvents      StayStatusEvent[]
  paymentsVerified  Payment[]         @relation("VerifiedPayments")
  refundsProcessed  RefundInvoice[]   @relation("ProcessedRefunds")
  documentsUploaded Document[]        @relation("UploadedDocuments")
  leadNotes         LeadNote[]
  notifications     Notification[]
  ticketComments    TicketComment[]
  activityLogsActed ActivityLog[]     @relation("ActivityActor")

  foodPricingsCreated            FoodPricing[]
  foodBillingCyclesClosed        FoodBillingCycle[]
  topUpApprovals                 FoodWalletTopUp[]         @relation("TopUpApprovals")
  foodSettlementsCreated         FoodSettlementStatement[]
  complementaryFoodOrdersCreated ComplementaryFoodOrder[]

  tasksCreated Task[] @relation("TasksCreated")
  taskComments TaskComment[]

  @@index([organizationId])
}

model Warden {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hostelId  String   @unique
  hostel    Hostel   @relation(fields: [hostelId], references: [id])
  createdAt DateTime @default(now())

  // Inverse relations
  onboardingRequests OnboardingRequest[]
  tasks              Task[]
}

enum OccupationType {
  STUDENT
  WORKING_PROFESSIONAL
}

model Tenant {
  id                          String          @id @default(uuid())
  userId                      String?         @unique
  user                        User?           @relation(fields: [userId], references: [id])
  fullName                    String
  dateOfBirth                 DateTime?
  gender                      String?
  placeOfBirth                String?
  permanentAddress            String?
  emergencyContactName        String?
  relationship                String?
  emergencyContactNumber      String?
  additionalEmergencyContacts Json?
  parentGuardianName          String?
  parentGuardianContact       String?
  occupationType              OccupationType?
  collegeName                 String?
  courseOrBranch              String?
  companyName                 String?
  designation                 String?
  purposeOfStay               String?
  photoUrl                    String?
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt

  // Inverse relations
  stays     Stay[]
  documents Document[]
  tickets   Ticket[]
}

// ==========================================
// 4.2 Building Hierarchy Models
// ==========================================

enum AccommodationType {
  MENS
  WOMENS
}

model Hostel {
  id                       String            @id @default(uuid())
  name                     String
  address                  String
  accommodationType        AccommodationType
  locationId               String?
  location                 Location?         @relation(fields: [locationId], references: [id])
  affidavitText            String?
  foodOrderCutoffStartHour Int               @default(20) // 8 PM
  foodOrderCutoffEndHour   Int               @default(6) // 6 AM
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  organizationId           String
  organization             Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Inverse relations
  warden                  Warden?
  paymentConfig           HostelPaymentConfig?
  floors                  Floor[]
  stays                   Stay[]
  leads                   Lead[]
  onboardingRequests      OnboardingRequest[]
  tickets                 Ticket[]
  activityLogs            ActivityLog[]
  foodPricings            FoodPricing[]
  complementaryFoodOrders ComplementaryFoodOrder[]
  tasks                   Task[]

  @@index([organizationId])
}

model HostelPaymentConfig {
  id         String   @id @default(uuid())
  hostelId   String   @unique
  hostel     Hostel   @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  upiId      String?
  qrCodePath String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Location {
  id        String   @id @default(uuid())
  name      String   @unique
  hostels   Hostel[]
  createdAt DateTime @default(now())
}

model Floor {
  id        String @id @default(uuid())
  hostelId  String
  hostel    Hostel @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int
  flats     Flat[]
  rooms     Room[]
}

model Flat {
  id        String  @id @default(uuid())
  floorId   String
  floor     Floor   @relation(fields: [floorId], references: [id], onDelete: Cascade)
  name      String
  isPrivate Boolean @default(false)
  rooms     Room[]
}

model Room {
  id          String      @id @default(uuid())
  flatId      String?
  flat        Flat?       @relation(fields: [flatId], references: [id], onDelete: Cascade)
  floorId     String?
  floor       Floor?      @relation(fields: [floorId], references: [id], onDelete: Cascade)
  roomNumber  String
  sharingType SharingType
  isPrivate   Boolean     @default(false)
  beds        Bed[]

  // Note: Exactly one of Room.flatId or Room.floorId must be set.
  // Enforced via application level validation.
}

enum SharingType {
  SINGLE
  DOUBLE
  TRIPLE
  FOUR
  SIX
  EIGHT
}

enum BedType {
  UPPER_BERTH
  LOWER_BERTH
  SINGLE_COT
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  IN_MAINTENANCE
  ON_HOLD
  NOT_IN_USE
}

model Bed {
  id      String    @id @default(uuid())
  roomId  String
  room    Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  label   String
  bedType BedType?
  status  BedStatus @default(AVAILABLE)

  // Inverse relations
  stays              Stay[]
  onboardingRequests OnboardingRequest[]
}

// ==========================================
// 4.3 Stay & Onboarding Models
// ==========================================

enum OnboardingRequestStatus {
  PENDING
  COMPLETED
  EXPIRED
}

model OnboardingRequest {
  id                    String                  @id @default(uuid())
  phone                 String
  hostelId              String
  hostel                Hostel                  @relation(fields: [hostelId], references: [id])
  bedId                 String
  bed                   Bed                     @relation(fields: [bedId], references: [id])
  wardenId              String
  warden                Warden                  @relation(fields: [wardenId], references: [id])
  status                OnboardingRequestStatus @default(PENDING)
  tempPasswordHash      String?
  onboardingCurrentStep Int                     @default(0)
  failedAttempts        Int                     @default(0)
  lockedUntil           DateTime?
  createdAt             DateTime                @default(now())
  // Note: Unique index on phone where status = PENDING should be enforced at db/migration or application level.

  @@index([phone])
  @@index([phone, status])
}

enum StayStatus {
  ONBOARDING_PENDING
  APPROVED_AWAITING_PAYMENT
  ACTIVE
  EXTENDED
  EARLY_EXIT
  CHECKED_OUT
  CANCELLED
}

enum DurationType {
  MONTHLY
  WEEKLY
  DAILY
  CUSTOM
}

enum FoodPlan {
  NOT_INCLUDED
  BREAKFAST_ONLY
  BREAKFAST_DINNER
  BLD
}

enum FoodBillingMode {
  PREPAID_CONSUMPTION
  POSTPAID
  FLAT_RATE
}

model Stay {
  id                   String          @id @default(uuid())
  tenantId             String
  tenant               Tenant          @relation(fields: [tenantId], references: [id])
  bedId                String
  bed                  Bed             @relation(fields: [bedId], references: [id])
  hostelId             String // denormalized for speed
  hostel               Hostel          @relation(fields: [hostelId], references: [id])
  status               StayStatus
  durationType         DurationType
  joiningDate          DateTime
  endDate              DateTime?
  isNewAdmission       Boolean
  admissionFeePaise    Int
  monthlyRentPaise     Int
  securityDepositPaise Int
  foodChargesPaise     Int
  foodBillingMode      FoodBillingMode @default(FLAT_RATE)
  foodPlan             FoodPlan        @default(NOT_INCLUDED)
  foodPlanStartDate    DateTime?
  foodPlanEndDate      DateTime?
  totalPayablePaise    Int
  discountPaise        Int
  marketingExecutive   String?
  leadSource           String?
  commissionStatus     String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  // Inverse relations
  statusEvents    StayStatusEvent[]
  payments        Payment[]
  refundInvoices  RefundInvoice[]
  foodOrders      FoodOrder[]
  documents       Document[]
  serviceRequests ServiceRequest[]

  foodBillingCycles FoodBillingCycle[]
  foodWalletTopUps  FoodWalletTopUp[]
  foodSettlements   FoodSettlementStatement[]

  // Indexes
  @@index([bedId, status])
  @@index([hostelId, status])
  @@index([endDate])
}

model StayStatusEvent {
  id              String     @id @default(uuid())
  stayId          String
  stay            Stay       @relation(fields: [stayId], references: [id], onDelete: Cascade)
  fromStatus      StayStatus
  toStatus        StayStatus
  changedByUserId String
  changedByUser   User       @relation(fields: [changedByUserId], references: [id])
  note            String?
  createdAt       DateTime   @default(now())
}

// ==========================================
// 4.4 Payments & Financial Models
// ==========================================

enum PaymentMode {
  CASH
  UPI
  COMPANY_ACCOUNT
  BANK_TRANSFER
}

enum PaymentStatus {
  PAID
  PARTIALLY_PAID
  PENDING
}

model Payment {
  id                   String        @id @default(uuid())
  stayId               String
  stay                 Stay          @relation(fields: [stayId], references: [id], onDelete: Cascade)
  amountPaidPaise      Int
  paymentMode          PaymentMode
  transactionRefNo     String?
  receivedBy           String?
  paymentStatus        PaymentStatus
  notes                String?
  verifiedByUserId     String?
  verifiedByUser       User?         @relation("VerifiedPayments", fields: [verifiedByUserId], references: [id])
  verifiedAt           DateTime?
  screenshotDocumentId String?       @unique
  screenshotDocument   Document?     @relation("PaymentScreenshot", fields: [screenshotDocumentId], references: [id])
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  receiptNumber        Int           @default(autoincrement())

  serviceRequest ServiceRequest?

  @@index([stayId])
  @@index([paymentStatus, createdAt])
}

model RefundInvoice {
  id                  String   @id @default(uuid())
  stayId              String
  stay                Stay     @relation(fields: [stayId], references: [id], onDelete: Cascade)
  originalAmountPaise Int
  daysUsed            Int
  daysRemaining       Int
  refundAmountPaise   Int
  processedByUserId   String
  processedByUser     User     @relation("ProcessedRefunds", fields: [processedByUserId], references: [id])
  notes               String?
  pdfDocumentId       String   @unique
  pdfDocument         Document @relation("RefundInvoicePDF", fields: [pdfDocumentId], references: [id])
  createdAt           DateTime @default(now())
}

// ==========================================
// 4.5 Food, Documents & Leads
// ==========================================

model FoodOrder {
  id          String    @id @default(uuid())
  stayId      String
  stay        Stay      @relation(fields: [stayId], references: [id], onDelete: Cascade)
  forDate     DateTime
  breakfast   Boolean
  lunch       Boolean
  dinner      Boolean
  confirmedAt DateTime?
  lockedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([stayId, forDate])
}

enum DocumentOwnerType {
  TENANT
  STAY
}

enum DocumentType {
  AADHAAR
  PAN
  PASSPORT_PHOTO
  COLLEGE_ID
  COMPANY_ID
  PROFILE_PHOTO
  PAYMENT_SCREENSHOT
  REGISTRATION_FORM_PDF
  RECEIPT_PDF
  REFUND_INVOICE_PDF
  OTHER
}

model Document {
  id               String            @id @default(uuid())
  ownerType        DocumentOwnerType
  tenantId         String?
  tenant           Tenant?           @relation(fields: [tenantId], references: [id])
  stayId           String?
  stay             Stay?             @relation(fields: [stayId], references: [id])
  documentType     DocumentType
  storagePath      String
  fileSizeBytes    Int
  uploadedByUserId String
  uploadedByUser   User              @relation("UploadedDocuments", fields: [uploadedByUserId], references: [id])
  createdAt        DateTime          @default(now())

  // Inverse 1-1 relations for screenshots/refunds
  paymentScreenshot Payment?       @relation("PaymentScreenshot")
  refundInvoicePDF  RefundInvoice? @relation("RefundInvoicePDF")

  @@index([ownerType, tenantId])
  @@index([ownerType, stayId])
}

enum LeadSource {
  WHATSAPP_BOT
  MANUAL
}

enum LeadStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  CONVERTED
  DROPPED
}

model Lead {
  id             String       @id @default(uuid())
  hostelId       String?
  hostel         Hostel?      @relation(fields: [hostelId], references: [id])
  phone          String
  source         LeadSource
  status         LeadStatus   @default(NEW)
  notes          LeadNote[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model LeadNote {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  note      String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())

  @@index([leadId])
}

// ==========================================
// Multi-Tenant SaaS Models
// ==========================================

model Organization {
  id         String   @id @default(uuid())
  name       String
  domain     String?  @unique
  brandColor String?
  logoUrl    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  hostels      Hostel[]
  users        User[]
  leads        Lead[]
  activityLogs ActivityLog[]
  foodPricings FoodPricing[]
  tasks        Task[]
  taskComments TaskComment[]
}

// ==========================================
// Service Request (Ad-hoc Billing) Models
// ==========================================

enum ServiceRequestType {
  FOOD_PLAN_UPGRADE
  ROOM_CHANGE
  FINE
  OTHER
}

enum ServiceRequestStatus {
  PENDING_PAYMENT
  PAYMENT_UPLOADED
  VERIFIED
  REJECTED
  REVOKED
}

model ServiceRequest {
  id          String               @id @default(uuid())
  stayId      String
  stay        Stay                 @relation(fields: [stayId], references: [id], onDelete: Cascade)
  type        ServiceRequestType
  amountPaise Int
  metadata    Json?
  status      ServiceRequestStatus @default(PENDING_PAYMENT)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  paymentId String?  @unique
  payment   Payment? @relation(fields: [paymentId], references: [id])

  @@index([stayId, status])
}

model Notification {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title             String
  message           String
  type              String // e.g. "FOOD_PLAN", "PAYMENT", "ONBOARDING", "TICKET"
  targetUrl         String? // the URL to navigate to when the notification is clicked
  referenceId       String? // ID of the related entity (e.g. Ticket ID)
  read              Boolean  @default(false)
  dismissedFromHome Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@index([userId, read])
}

// ==========================================
// Ticketing / Complaint System
// ==========================================

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketCategory {
  MAINTENANCE
  CLEANING
  ELECTRICAL
  PLUMBING
  OTHER
}

model Ticket {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  hostelId String
  hostel   Hostel @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  title       String
  description String
  priority    TicketPriority @default(NORMAL)
  status      TicketStatus   @default(OPEN)
  category    TicketCategory @default(OTHER)

  resolvedAt DateTime?
  closedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments TicketComment[]

  @@index([hostelId, status])
  @@index([tenantId])
}

model TicketComment {
  id         String   @id @default(uuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  message    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ==========================================
// Activity Logging System
// ==========================================

enum ActivityEventType {
  // Stay Lifecycle
  TENANT_ONBOARDING_STARTED
  TENANT_ONBOARDED
  TENANT_PAYMENT_RECEIVED
  TENANT_CHECKED_OUT
  STAY_STATUS_CHANGED

  // Tickets
  TICKET_RAISED
  TICKET_STATUS_UPDATED
  TICKET_COMMENT_ADDED

  // Food
  FOOD_ORDER_UPDATED
  FOOD_CYCLE_CLOSED
  FOOD_WALLET_TOPPED_UP
  FOOD_WALLET_TOPUP_REJECTED
  FOOD_COMPLEMENTARY_ORDER_CREATED

  // Service Requests
  SERVICE_REQUEST_CREATED
  SERVICE_REQUEST_RESOLVED
}

model ActivityLog {
  id             String            @id @default(uuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hostelId       String?
  hostel         Hostel?           @relation(fields: [hostelId], references: [id], onDelete: SetNull)
  eventType      ActivityEventType
  actorId        String?
  actor          User?             @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorName      String // denormalized
  subjectName    String // denormalized
  subjectId      String?
  subjectType    String? // "Stay" | "Ticket" | "Payment" | "FoodOrder"
  metadata       Json?
  targetUrl      String?
  createdAt      DateTime          @default(now())

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([hostelId, createdAt(sort: Desc)])
}

// ==========================================
// 4.6 Food Billing System Models
// ==========================================

model FoodPricing {
  id                  String       @id @default(uuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hostelId            String? // null = org-wide default; set = hostel override
  hostel              Hostel?      @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  breakfastPricePaise Int // price of one breakfast portion in paise
  lunchPricePaise     Int
  dinnerPricePaise    Int
  effectiveFrom       DateTime // price active from this date
  createdAt           DateTime     @default(now())
  createdByUserId     String
  createdByUser       User         @relation(fields: [createdByUserId], references: [id])

  @@index([organizationId, effectiveFrom(sort: Desc)])
  @@index([hostelId, effectiveFrom(sort: Desc)])
}

enum FoodBillingCycleStatus {
  OPEN
  SETTLING
  CLOSED
}

model FoodBillingCycle {
  id         String                 @id @default(uuid())
  stayId     String
  stay       Stay                   @relation(fields: [stayId], references: [id], onDelete: Cascade)
  cycleStart DateTime
  cycleEnd   DateTime
  status     FoodBillingCycleStatus @default(OPEN)

  // Snapshot of meal prices at cycle start (frozen for audit)
  breakfastPricePaise Int
  lunchPricePaise     Int
  dinnerPricePaise    Int

  // Totals computed at close time
  totalConsumedPaise Int?
  totalPaidPaise     Int? // initial deposit + top-ups within this cycle
  settlementPaise    Int? // positive = refund; negative = due
  closedAt           DateTime?
  closedByUserId     String?
  closedByUser       User?     @relation(fields: [closedByUserId], references: [id])

  createdAt DateTime @default(now())

  topUps     FoodWalletTopUp[]
  settlement FoodSettlementStatement?

  @@unique([stayId, cycleStart])
  @@index([stayId, status])
  @@index([cycleEnd, status]) // for cron job querying open cycles past their end date
}

enum TopUpStatus {
  PENDING // tenant-initiated, awaiting warden approval
  APPROVED // recorded and added to wallet
  REJECTED // warden rejected the request
}

model FoodWalletTopUp {
  id                      String           @id @default(uuid())
  stayId                  String
  stay                    Stay             @relation(fields: [stayId], references: [id], onDelete: Cascade)
  cycleId                 String
  cycle                   FoodBillingCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  amountPaise             Int
  paymentMode             PaymentMode? // null if status = PENDING
  transactionRef          String?
  status                  TopUpStatus      @default(PENDING)
  reason                  String? // optional note
  requestedByTenantUserId String? // set if tenant-initiated
  approvedByUserId        String?
  approvedByUser          User?            @relation("TopUpApprovals", fields: [approvedByUserId], references: [id])
  idempotencyKey          String?          @unique
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@index([stayId, cycleId])
  @@index([cycleId, status])
}

enum SettlementOutcome {
  REFUND_DUE // hostel owes tenant money
  AMOUNT_DUE // tenant owes hostel money
  SETTLED // zero balance; nothing to do
}

model FoodSettlementStatement {
  id                 String            @id @default(uuid())
  stayId             String
  stay               Stay              @relation(fields: [stayId], references: [id], onDelete: Cascade)
  cycleId            String            @unique
  cycle              FoodBillingCycle  @relation(fields: [cycleId], references: [id])
  totalConsumedPaise Int
  totalPaidPaise     Int
  balancePaise       Int // positive = refund; negative = due
  outcome            SettlementOutcome
  notes              String?
  createdAt          DateTime          @default(now())
  createdByUserId    String
  createdByUser      User              @relation(fields: [createdByUserId], references: [id])

  @@index([stayId])
}

enum ComplementaryOrderCategory {
  GUEST
  STAFF
  EVENT
  OTHER
}

model ComplementaryFoodOrder {
  id              String                     @id @default(uuid())
  hostelId        String
  hostel          Hostel                     @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  forDate         DateTime
  category        ComplementaryOrderCategory
  reason          String // required; e.g. "Guest – visiting parents of Rahul"
  breakfastQty    Int                        @default(0)
  lunchQty        Int                        @default(0)
  dinnerQty       Int                        @default(0)
  totalCostPaise  Int // computed at creation: (bQty × bPrice + ...) 
  createdByUserId String
  createdByUser   User                       @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime                   @default(now())

  @@index([hostelId, forDate])
}

// ==========================================
// Task Assignment System
// ==========================================

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Task {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Assignment
  createdByUserId    String?
  createdBy          User?  @relation("TasksCreated", fields: [createdByUserId], references: [id], onDelete: SetNull)
  assignedToWardenId String
  assignedToWarden   Warden @relation(fields: [assignedToWardenId], references: [id], onDelete: Restrict)
  hostelId           String
  hostel             Hostel @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  // Task Content
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(PENDING)
  deadline    DateTime

  // Completion
  completedAt    DateTime?
  completionNote String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  comments TaskComment[]

  @@index([organizationId])
  @@index([assignedToWardenId, status])
  @@index([hostelId])
  @@index([deadline])
}

model TaskComment {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  taskId         String
  task           Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  message        String
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([taskId])
}
